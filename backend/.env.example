# Turso Database Configuration
TURSO_DATABASE_URL=libsql://expensetracker-khachonb.aws-ap-northeast-1.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Server Configuration
SERVER_PORT=8080

# Security — all three are required; the server will refuse to start if any are missing
JWT_SECRET=your-jwt-secret-here
PEPPER_SECRET=your-pepper-secret-here
ADMIN_USERNAMES=admin
